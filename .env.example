# ============================================
# RCT-Reviewer Configuration
# ============================================
# Copy this file to .env and adjust as needed

# --- General ---
RCT_REVIEWER_DEBUG=false
RCT_REVIEWER_LOG_LEVEL=INFO


# --- ML Models ---
RCT_REVIEWER_MODEL__RCT_MODEL_NAME=microsoft/BiomedNLP-PubMedBERT-base-uncased-abstract-fulltext
RCT_REVIEWER_MODEL__PICO_MODEL_NAME=dmis-lab/biobert-v1.1
RCT_REVIEWER_MODEL__BIAS_MODEL_NAME=microsoft/BiomedNLP-PubMedBERT-base-uncased-abstract-fulltext
RCT_REVIEWER_MODEL__NER_MODEL_NAME=dmis-lab/biobert-v1.1
RCT_REVIEWER_MODEL__DEVICE=auto
RCT_REVIEWER_MODEL__BATCH_SIZE=8
RCT_REVIEWER_MODEL__MAX_LENGTH=512
# RCT_REVIEWER_MODEL__CACHE_DIR=/path/to/cache

# --- Processing ---
RCT_REVIEWER_PROCESSING__SPACY_MODEL=en_core_web_sm
RCT_REVIEWER_PROCESSING__MAX_SENTENCES=500
RCT_REVIEWER_PROCESSING__PICO_TOP_K=3
RCT_REVIEWER_PROCESSING__BIAS_TOP_K=3
